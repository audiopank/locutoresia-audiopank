{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python@4.3.0",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12",
        "includeFiles": "{static,templates}/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/publish-news", "schedule": "0 12 * * *" },
    { "path": "/api/cron/publish-news", "schedule": "0 15 * * *" },
    { "path": "/api/cron/publish-news", "schedule": "0 21 * * *" }
  ],
  "env": {
    "FLASK_ENV": "production",
    "VERCEL": "1",
    "PYTHONUNBUFFERED": "1"
  }
}
